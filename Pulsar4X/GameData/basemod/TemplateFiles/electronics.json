  {
    "Type": "ComponentTemplate",
    "Payload": {
      "UniqueID": "sensor-hardening-module",
      "Name": "Sensor Hardening Module",
      "Formulas": {
        "Description": "Shields a ship's sensors against the jamming/blinding of space hazards (gas clouds, solar flares). The counter to a hazard's SensorJam effect.",
        "Mass": "PropertyValue('Mass')",
        "Volume": "[Mass]",
        "HTK": "0.5",
        "CrewReq": "Max(1, [Mass] * 0.01)",
        "ResearchCost": "[Mass] * 2",
        "CreditCost": "[Mass]",
        "BuildPointCost": "[Mass]"
      },
      "ResourceCost": {
        "stainless-steel": "[Mass] * 0.4",
        "aluminium": "[Mass] * 0.2",
        "copper": "[Mass] * 0.2",
        "plastic": "[Mass] * 0.1"
      },
      "ComponentType": "Sensor",
      "MountType": "ShipComponent, ShipCargo, PlanetInstallation, Fighter",
      "CargoTypeID": "general-storage",
      "IndustryTypeID": "component-construction",
      "Properties": [
        {
          "Name": "Resisted Effect",
          "DescriptionFormula": "'Which hazard effect this resists, as the HazardEffectType enum value (SensorJam = 3).'",
          "GuiHint": "GuiSelectionMaxMinInt",
          "MaxFormula": "5",
          "MinFormula": "0",
          "StepFormula": "1",
          "PropertyFormula": "3"
        },
        {
          "Name": "Resistance",
          "Units": "fraction",
          "DescriptionFormula": "'How strongly it shrinks the hazard effect (0..1). Stacks across modules.'",
          "GuiHint": "GuiSelectionMaxMin",
          "MaxFormula": "0.9",
          "MinFormula": "0.1",
          "StepFormula": "0.05",
          "PropertyFormula": "0.6"
        },
        {
          "Name": "Mass",
          "Units": "kg",
          "GuiHint": "None",
          "PropertyFormula": "100 + 200 * PropertyValue('Resistance')"
        },
        {
          "Name": "hazardResistAtbArgs",
          "DescriptionFormula": "'double resistedEffectTypeId, double resistanceFraction'",
          "GuiHint": "None",
          "PropertyFormula": "AtbConstrArgs(PropertyValue('Resisted Effect'), PropertyValue('Resistance'))",
          "AttributeType": "Pulsar4X.Hazards.HazardResistanceAtb"
        }
      ]
    }
  },
  {
    "Type": "ComponentTemplate",
    "Payload": {
      "UniqueID": "passive-sensor",
      "Name": "Passive Sensor",
      "Formulas": {
        "Description": "Detects emissions and reflections from other objects",
        "Mass": "PropertyValue('Mass')",
        "Volume": "PropertyValue('Mass')",
        "HTK": "0.5",
        "CrewReq": "Max(1, [Mass] * 0.01)",
        "ResearchCost": "[Mass] * 2",
        "CreditCost": "[Mass]",
        "BuildPointCost": "[Mass]"
      },
      "ResourceCost": {
        "stainless-steel": "[Mass] * 0.5",
        "plastic": "[Mass] * 0.2",
        "aluminium": "[Mass] * 0.1",
        "copper": "[Mass] * 0.1"
      },
      "ComponentType": "Sensor",
      "MountType": "PlanetInstallation, ShipComponent, ShipCargo, Fighter",
      "IndustryTypeID": "component-construction",
      "CargoTypeID": "general-storage",
      "Properties": [
        {
          "Name": "Antenna Size",
          "Units": "m^2",
          "DescriptionFormula": "'Gives an effective area of:  '",
          "GuiHint": "GuiSelectionMaxMin",
          "MaxFormula": "2500",
          "MinFormula": "1",
          "StepFormula": "1",
          "PropertyFormula": "1.25"
        },
        {
          "Name": "Effective Size",
          "Units": "m^2",
          "GuiHint": "None",
          "PropertyFormula": "PropertyValue('Antenna Size') * TechData('tech-antenna-efficiency')"
        },
        {
          "Name": "Ideal Detection Wavelength",
          "Units": "nm",
          "DescriptionFormula": "'The wavelength this sensor is most efficient at detecting'",
          "GuiHint": "GuiSelectionMaxMin",
          "MaxFormula": "1e12",
          "MinFormula": "0.01",
          "StepFormula": "1",
          "PropertyFormula": "600"
        },
        {
          "Name": "Detection Bandwidth",
          "Units": "nm",
          "DescriptionFormula": "'How far from the ideal wavelength will this still detect a signal'",
          "GuiHint": "GuiSelectionMaxMin",
          "MaxFormula": "TechData('tech-antenna-bandwidth')",
          "MinFormula": "1",
          "StepFormula": "1",
          "PropertyFormula": "250"
        },
        {
          "Name": "Efficiency",
          "GuiHint": "GuiTextDisplay",
          "PropertyFormula": "1 / (PropertyValue('Detection Bandwidth') / TechData('tech-antenna-bandwidth') )"
        },
        {
          "Name": "Sensitivity at Ideal Wavelength",
          "Units": "W",
          "DescriptionFormula": "'Smallest signal this can detect at the ideal wavelength, lower is better.",
          "GuiHint": "GuiTextDisplay",
          "PropertyFormula": "TechData('tech-antenna-sensitivity') / (PropertyValue('Effective Size') * PropertyValue('Effective Size') * PropertyValue('Efficiency'))"
        },
        {
          "Name": "Sensitivity at Worst Wavelength",
          "Units": "W",
          "DescriptionFormula": "'Smallest signal this can detect at the worst wavelength, lower is better.'",
          "GuiHint": "GuiTextDisplay",
          "PropertyFormula": "TechData('tech-antenna-sensitivity') / (PropertyValue('Effective Size') * PropertyValue('Effective Size') * PropertyValue('Efficiency') * 0.1)"
        },
        {
          "Name": "Resolution",
          "Units": "MegaPixel",
          "DescriptionFormula": "'How much detail it can get from a detection. affects likelyhood of component detection etc. '",
          "GuiHint": "GuiSelectionMaxMin",
          "MaxFormula": "1000",
          "MinFormula": "0.1",
          "StepFormula": "1",
          "PropertyFormula": "1"
        },
        {
          "Name": "Scan Time",
          "Units": "s",
          "DescriptionFormula": "'how long it takes to complete a full scan'",
          "GuiHint": "GuiSelectionMaxMin",
          "MaxFormula": "86400",
          "MinFormula": "1",
          "StepFormula": "1",
          "PropertyFormula": "3600"
        },
        {
          "Name": "Mass",
          "Units": "kg",
          "DescriptionFormula": "'Mass Calculation'",
          "GuiHint": "None",
          "PropertyFormula": "90 + 0.01 * PropertyValue('Antenna Size') * PropertyValue('Antenna Size')"
        },
        {
          "Name": "DatablobArguments",
          "DescriptionFormula": "'(double peakWaveLength, double bandwidth, double bestSensitivity, double worstSensitivity, double resolution, double scanTime)'",
          "GuiHint": "None",
          "PropertyFormula": "AtbConstrArgs(PropertyValue('Ideal Detection Wavelength'), PropertyValue('Detection Bandwidth'), PropertyValue('Sensitivity at Ideal Wavelength'), PropertyValue('Sensitivity at Worst Wavelength'), PropertyValue('Resolution'), PropertyValue('Scan Time'), 200000000000)",
          "AttributeType": "Pulsar4X.Sensors.SensorReceiverAtb"
        }
      ]
    }
  },
