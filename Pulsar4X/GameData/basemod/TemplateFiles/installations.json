      "IndustryTypeID": "installation-construction",
      "Properties": [
        {
          "Name": "Support Colonists",
          "DescriptionFormula": "'Population supported when the body's gravity and atmosphere fall within tolerance. Out-of-tolerance bodies receive no support from this design.'",
          "GuiHint": "GuiTextDisplay",
          "PropertyFormula": "500"
        },
        {
          "Name": "Storage Amount",
          "DescriptionFormula": "'The amount of space that is dedicated to storage space. '",
          "GuiHint": "GuiTextDisplay",
          "PropertyFormula": "500"
        },
        {
          "Name": "Support Capacity",
          "DescriptionFormula": "'Support capacity each unit of this infrastructure provides to the colony. Other installations consume this capacity; if demand exceeds supply all colony output is reduced. Only counts on bodies within the gravity and pressure tolerances below.'",
          "GuiHint": "GuiTextDisplay",
          "PropertyFormula": "1000"
        },
        {
          "Name": "Housing Comfort",
          "DescriptionFormula": "'Quality-of-life comfort this infrastructure provides — a capped morale bonus on top of bare life-support. Basic utilities and housing keep colonists content, not just alive.'",
          "GuiHint": "GuiTextDisplay",
          "PropertyFormula": "5"
        },
        {
          "Name": "Min Gravity",
          "DescriptionFormula": "'Surface gravity range (m/s²) this infrastructure can operate in. Earth standard is 9.81 m/s². Drag the left/right handles to set the bounds; drag the bar between them to shift the whole range.'",
          "GuiHint": "GuiSelectionMinMaxRange",
          "PairedPropertyName": "Max Gravity",
          "MaxFormula": "Min(100, 9.81 * (1.0 + TechData('tech-infra-gravity-range') + TechData('tech-infra-gravity-max-extension')))",
          "MinFormula": "Max(0, 9.81 * (1.0 - TechData('tech-infra-gravity-range') - TechData('tech-infra-gravity-min-extension')))",
          "MaxRangeFormula": "9.81 * 2.0 * TechData('tech-infra-gravity-range')",
          "StepFormula": "0.1",
          "PropertyFormula": "8.8"
        },
        {
          "Name": "Max Gravity",
          "DescriptionFormula": "'Upper bound of the gravity operating range. Configured via the Min Gravity range slider.'",
          "GuiHint": "None",
          "MaxFormula": "Min(100, 9.81 * (1.0 + TechData('tech-infra-gravity-range') + TechData('tech-infra-gravity-max-extension')))",
          "MinFormula": "Max(0, 9.81 * (1.0 - TechData('tech-infra-gravity-range') - TechData('tech-infra-gravity-min-extension')))",
          "StepFormula": "0.1",
          "PropertyFormula": "10.8"
        },
        {
          "Name": "Min Pressure",
          "DescriptionFormula": "'Atmospheric pressure range (Earth atmospheres) this infrastructure can operate in. Drag the handles to set the bounds; drag the bar between them to shift the whole range.'",
          "GuiHint": "GuiSelectionMinMaxRange",
          "PairedPropertyName": "Max Pressure",
          "MaxFormula": "1.0 + TechData('tech-infra-pressure-range') + TechData('tech-infra-pressure-max-extension')",
          "MinFormula": "Max(0, 1.0 - TechData('tech-infra-pressure-range') - TechData('tech-infra-pressure-min-extension'))",
          "MaxRangeFormula": "2.0 * TechData('tech-infra-pressure-range')",
          "StepFormula": "0.1",
          "PropertyFormula": "0.9"
        },
        {
          "Name": "Max Pressure",
          "DescriptionFormula": "'Upper bound of the pressure operating range. Configured via the Min Pressure range slider.'",
          "GuiHint": "None",
          "MaxFormula": "1.0 + TechData('tech-infra-pressure-range') + TechData('tech-infra-pressure-max-extension')",
          "MinFormula": "Max(0, 1.0 - TechData('tech-infra-pressure-range') - TechData('tech-infra-pressure-min-extension'))",
          "StepFormula": "0.1",
          "PropertyFormula": "1.1"
        },
        {
          "Name": "DBargs",
          "GuiHint": "None",
          "PropertyFormula": "AtbConstrArgs(UniqueID('general-storage'), PropertyValue('Storage Amount'))",
          "AttributeType": "Pulsar4X.Storage.CargoStorageAtb"
        },
        {
          "Name": "DBargsPopSupport",
          "GuiHint": "None",
          "PropertyFormula": "AtbConstrArgs(PropertyValue('Support Colonists'))",
          "AttributeType": "Pulsar4X.Galaxy.PopulationSupportAtbDB"
        },
        {
          "Name": "DBargsCapacity",
          "GuiHint": "None",
          "PropertyFormula": "AtbConstrArgs(PropertyValue('Support Capacity'))",
          "AttributeType": "Pulsar4X.Industry.InfrastructureCapacityAtb"
        },
        {
          "Name": "DBargsHousing",
          "GuiHint": "None",
          "PropertyFormula": "AtbConstrArgs(PropertyValue('Housing Comfort'))",
          "AttributeType": "Pulsar4X.Colonies.HousingAtbDB"
        },
        {
          "Name": "DBargsGravity",
          "GuiHint": "None",
          "PropertyFormula": "AtbConstrArgs(PropertyValue('Min Gravity'), PropertyValue('Max Gravity'))",
          "AttributeType": "Pulsar4X.Galaxy.GravityToleranceAtb"
